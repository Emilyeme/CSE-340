<main class="account-container">
  <h1><%= title %></h1>

  <% if (messages && messages.notice) { %>
    <div class="notice">
      <%= messages.notice %>
    </div>
  <% } %>

  <p>Confirm Deletion - The delete is permanent.</p>

  <form action="/inv/delete" method="post">
    
    <!-- Hidden ID -->
    <input type="hidden" name="inv_id"
    <% if(locals.inv_id) { %> value="<%= locals.inv_id %>"
    <% } %>>

    <!-- Only Make, Model, Year, and Price with READONLY -->
    <div class="form-group">
      <label for="inv_make">Make</label>
      <input type="text" id="inv_make" name="inv_make" value="<%= inv_make %>" readonly>
    </div>

    <div class="form-group">
      <label for="inv_model">Model</label>
      <input type="text" id="inv_model" name="inv_model" value="<%= inv_model %>" readonly>
    </div>

    <div class="form-group">
      <label for="inv_year">Year</label>
      <input type="number" id="inv_year" name="inv_year" value="<%= inv_year %>" readonly>
    </div>

    <div class="form-group">
      <label for="inv_price">Price</label>
      <input type="number" id="inv_price" name="inv_price" value="<%= inv_price %>" readonly>
    </div>

    <button type="submit">Delete</button>
    
  </form>
</main>